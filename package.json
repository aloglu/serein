{
  "name": "serein",
  "version": "0.1.0",
  "private": true,
  "description": "Markdown-first static daily poem publisher",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "normalize:filenames": "node scripts/normalize-poem-filenames.mjs",
    "preview": "npx serve dist",
    "dev:preview": "concurrently -k -n build,serve -c yellow,cyan \"npm run dev\" \"npm run preview\"",
    "dev:preview:asof": "node scripts/dev-preview-asof.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "marked": "^16.4.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
